# Images published from main
FRONTEND_IMAGE=ghcr.io/kimwoonggon/woong-blog-java-springboot-nextjs-runtime-frontend:main
BACKEND_IMAGE=ghcr.io/kimwoonggon/woong-blog-java-springboot-nextjs-runtime-backend:main

# Compose / runtime
APP_ENV_FILE=.env.prod
NEXT_PUBLIC_SITE_URL=https://woonglab.com
NGINX_MAIN_CONF=./nginx/nginx.conf
# Local-only app bootstrap for first-run smoke. Do not use this with NGINX_BIND_HOST=0.0.0.0.
NGINX_DEFAULT_CONF=./nginx/prod-bootstrap.conf
NGINX_BIND_HOST=127.0.0.1
CERTBOT_WWW_DIR=./certbot/www
LETSENCRYPT_DIR=./certbot/conf
PROXY_KNOWN_NETWORK=172.16.0.0/12
CODEX_HOME_DIR=./.codex-runtime

# Real Backend Load Test
# Use https://woonglab.com to measure the public HTTPS/nginx path.
# Use http://127.0.0.1:8080 to measure the backend directly from the backend container.
LOAD_TESTING_BASE_URL=https://woonglab.com

# Keep main/prod localhost-only by default. Set NGINX_BIND_HOST=0.0.0.0 only when you intentionally publish the service.
# For external Let's Encrypt HTTP-01 issuance, temporarily set:
# NGINX_DEFAULT_CONF=./nginx/prod-acme-only.conf
# This exposes only /.well-known/acme-challenge/* and closes app routes such as /blog.

# Database
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me
POSTGRES_DATA_DIR=./.docker-data/prod/postgres
MEDIA_DATA_DIR=./.docker-data/prod/media
DATA_PROTECTION_DIR=./.docker-data/prod/data-protection
# 2CPU/8GiB default: keep backend pool below Postgres max_connections so diagnostics and admin access still have headroom.
POSTGRES_MAX_POOL_SIZE=40
POSTGRES_MIN_POOL_SIZE=0
# Optional explicit override. Normally derived from POSTGRES_* by docker-compose.prod.yml
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/portfolio

# Azure backup / restore
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BACKUP_CONTAINER=woong-blog-prod-backups
AZURE_BACKUP_PREFIX=woong-blog/prod
AZURE_BACKUP_LOG_FILE=./.docker-data/prod/azure-backup.log
AZURE_BACKUP_COMPOSE_FILE=docker-compose.prod.yml
AZURE_BACKUP_DB_SERVICE=db

# Auth / production
APP_AUTH_ENABLED=true
APP_AUTH_COOKIE_NAME=portfolio_auth
APP_AUTH_ADMIN_EMAILS=admin@example.com
APP_AUTH_MEDIA_ROOT=/app/media
APP_AUTH_SECURE_COOKIES=true
APP_AUTH_ENABLE_TEST_LOGIN_ENDPOINT=false
APP_AUTH_SESSION_TTL=PT8H
# Configure these as production secrets on the host or in GitHub/runner secret storage.
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=openid,profile,email

# Proxy / forwarded headers
# docker-compose.prod.yml injects PROXY_KNOWN_NETWORKS_0 from PROXY_KNOWN_NETWORK.

# AI / Codex
AI_PROVIDER=codex
CODEX_COMMAND=codex
CODEX_ARGUMENTS=exec
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=medium
CODEX_ALLOWED_MODELS=gpt-5.5,gpt-5.4,gpt-5.3-codex,gpt-5.3-codex-spark
CODEX_ALLOWED_REASONING_EFFORTS=low,medium,high,xhigh
CODEX_TIMEOUT_MS=180000
CODEX_WORKDIR=
AI_BATCH_CONCURRENCY=4
AI_BATCH_COMPLETED_RETENTION_DAYS=3

# Optional OpenAI / Azure OpenAI values when AI_PROVIDER is not codex
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional Cloudflare R2 values for media/video features
CloudflareR2__AccountId=
CloudflareR2__AccessKeyId=
CloudflareR2__SecretAccessKey=
CloudflareR2__BucketName=
CloudflareR2__Endpoint=
CloudflareR2__BrowserEndpoint=
CloudflareR2__PublicUrl=
CloudflareR2__ForceEnabledInDevelopment=false

# Security
SECURITY_USE_HTTPS_REDIRECTION=true
SECURITY_USE_HSTS=true

# Logging / hosting
AllowedHosts=*
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning
