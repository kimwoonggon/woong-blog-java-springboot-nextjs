# Images published from dev
FRONTEND_IMAGE=ghcr.io/your-owner/woong-blog-java-springboot-nextjs-runtime-frontend:dev
BACKEND_IMAGE=ghcr.io/your-owner/woong-blog-java-springboot-nextjs-runtime-backend:dev

# Compose / runtime
APP_ENV_FILE=.env.staging
NEXT_PUBLIC_SITE_URL=https://staging.example.com
NGINX_MAIN_CONF=./nginx/nginx.conf
NGINX_DEFAULT_CONF=./nginx/prod-bootstrap.conf
CERTBOT_WWW_DIR=./certbot/www
LETSENCRYPT_DIR=./certbot/conf
PROXY_KNOWN_NETWORK=172.16.0.0/12
CODEX_HOME_DIR=./.codex-runtime

# Real Backend Load Test
# Use the public staging nginx origin so timings include the same proxy path users hit.
LOAD_TESTING_BASE_URL=https://staging.example.com

# Database
POSTGRES_DB=portfolio_staging
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me
POSTGRES_DATA_DIR=./.docker-data/staging/postgres
POSTGRES_MAX_POOL_SIZE=40
POSTGRES_MIN_POOL_SIZE=0

# Auth / staging
APP_AUTH_ENABLED=true
APP_AUTH_COOKIE_NAME=portfolio_auth_staging
APP_AUTH_ADMIN_EMAILS=admin@example.com
APP_AUTH_MEDIA_ROOT=/app/media
APP_AUTH_SECURE_COOKIES=true
APP_AUTH_ENABLE_TEST_LOGIN_ENDPOINT=false
APP_AUTH_SESSION_TTL=PT8H
# Configure these as staging secrets on the host or in GitHub/runner secret storage.
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=openid,profile,email

# AI / Codex
AI_PROVIDER=codex
CODEX_COMMAND=codex
CODEX_ARGUMENTS=exec
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=medium
CODEX_ALLOWED_MODELS=gpt-5.5,gpt-5.4,gpt-5.3-codex,gpt-5.3-codex-spark
CODEX_ALLOWED_REASONING_EFFORTS=low,medium,high,xhigh
CODEX_TIMEOUT_MS=180000

# Security
SECURITY_USE_HTTPS_REDIRECTION=true
SECURITY_USE_HSTS=true
