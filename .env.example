# Frontend
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Host bind defaults. Keep localhost-only unless you explicitly want LAN/public access.
NGINX_BIND_HOST=127.0.0.1
BACKEND_BIND_HOST=127.0.0.1
# To expose nginx outside this machine, set NGINX_BIND_HOST=0.0.0.0 deliberately.
NGINX_MAIN_CONF=./nginx/nginx.conf

# Backend (Spring Boot)
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Auth
APP_AUTH_ENABLED=true
APP_AUTH_COOKIE_NAME=portfolio_auth_dev
APP_AUTH_ADMIN_EMAILS=admin@example.com
APP_AUTH_MEDIA_ROOT=/app/media
APP_AUTH_SECURE_COOKIES=false
APP_AUTH_ENABLE_TEST_LOGIN_ENDPOINT=true
APP_AUTH_SESSION_TTL=PT8H
# Optional Google OAuth2 client. Prefer real secrets outside committed env files.
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=openid,profile,email

# Proxy / forwarded headers
PROXY_KNOWN_NETWORK=172.16.0.0/12

# Security hardening
SECURITY_USE_HTTPS_REDIRECTION=false
SECURITY_USE_HSTS=false

# Database bootstrap
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DATA_DIR=./.docker-data/dev/postgres
# Keep the backend from consuming all PostgreSQL connections on 2CPU/8GiB-class hosts.
POSTGRES_MAX_POOL_SIZE=40
POSTGRES_MIN_POOL_SIZE=0

# AI providers (backend-owned admin AI)
AI__Provider=Codex
AI_PROVIDER=codex
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview
CODEX_COMMAND=codex
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=medium
CODEX_ALLOWED_MODELS=gpt-5.5,gpt-5.4,gpt-5.3-codex,gpt-5.3-codex-spark
CODEX_ALLOWED_REASONING_EFFORTS=low,medium,high,xhigh
CODEX_TIMEOUT_MS=180000
CODEX_WORKDIR=
AI_BATCH_CONCURRENCY=4
AI_BATCH_COMPLETED_RETENTION_DAYS=3

# Notion migration scripts
NOTION_TOKEN=
NOTIONAPI=
NOTION_SOURCE_DATABASE_ID=
NOTION_SOURCE_PAGE_ID=
Notion__DefaultPageSize=20
Notion__ImportBucket=blogs/notion
